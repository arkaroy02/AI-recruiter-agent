# OpenRouter API Key (get free key at https://openrouter.ai/keys)
# OpenRouter provides access to Claude, GPT-4, Llama, Gemini, and more
OPEN_ROUTER_TOKEN=your_openrouter_api_key_here

# Ollama Configuration (legacy - no longer used)
OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_MODEL=tinyllama:latest
OLLAMA_INTERVIEW_MODEL=gemma2:2b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# OpenRouter model configuration (free tier models)
# Available models: https://openrouter.ai/models
HF_CHAT_MODEL=meta-llama/llama-3.3-70b-instruct:free
HF_INTERVIEW_MODEL=meta-llama/llama-3.3-70b-instruct:free
HF_EMBED_MODEL=local
