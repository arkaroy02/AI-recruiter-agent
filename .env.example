# OpenRouter API Key (get key at https://openrouter.ai/keys)
# OpenRouter provides access to Claude, GPT-4, Llama, Gemini, DeepSeek, and more
OPEN_ROUTER_TOKEN=your_openrouter_api_key_here

# Ollama Configuration (legacy - no longer used)
OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_MODEL=tinyllama:latest
OLLAMA_INTERVIEW_MODEL=gemma2:2b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# OpenRouter model configuration (affordable, high-quality models)
# Pricing: https://openrouter.ai/models
# DeepSeek Chat: $0.14/1M tokens - Excellent quality/price ratio
# Gemini Flash: $0.075/1M tokens - Fast and capable
HF_CHAT_MODEL=deepseek/deepseek-chat
HF_INTERVIEW_MODEL=google/gemini-flash-1.5
HF_EMBED_MODEL=local
